# Firebase / Google Cloud – העתק ל-.env והכנס ערכים אמיתיים מ-Google Cloud Console
# לא להעלות את קובץ .env ל-Git!

# אחרי דליפת מפתח: ליצור מפתח חדש ב-Console → Credentials → Regenerate key
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=cteennetivot-216e7.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=cteennetivot-216e7
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=cteennetivot-216e7.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1092504252242
EXPO_PUBLIC_FIREBASE_APP_ID=1:1092504252242:ios:1bce1c4dea5b07a314148b

# Android build ב-EAS: אפשר להדביק כאן את כל תוכן google-services.json
# ואז app.config.ts ייצור את הקובץ אוטומטית בזמן build.
# GOOGLE_SERVICES_JSON={"project_info":{...}}

# אופציונלי: כתובת Cloud Function ללימוד יומי (אחרי firebase deploy --only functions)
# EXPO_PUBLIC_CHABAD_DAILY_API_URL=https://us-central1-cteennetivot-216e7.cloudfunctions.net/chabadDailyLessons
